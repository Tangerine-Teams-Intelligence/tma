# Top-level env template. Copy to .env and fill in.
# This file is sourced by tooling that doesn't read ~/.tmi/config.yaml directly.
# The bot has its own bot/.env.example with the same vars.

# Discord bot — see SETUP.md §2 for how to create
DISCORD_TOKEN=

# OpenAI Whisper API — see SETUP.md §3
OPENAI_API_KEY=

# Optional: override Claude CLI subprocess mode
# Values: real (default) | stub | mock
TMI_CLAUDE_MODE=real
