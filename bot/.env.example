# Tangerine Meeting Assistant — bot env vars.
# Copy to .env (or export in shell) and fill in real values.

# Discord bot token from https://discord.com/developers/applications
# Required scopes: bot, applications.commands
# Required gateway intents: Guilds, GuildVoiceStates
DISCORD_BOT_TOKEN=

# OpenAI API key with Whisper access
OPENAI_API_KEY=
