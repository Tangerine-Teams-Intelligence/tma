{
  "name": "tangerine-mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol server that exposes Tangerine team memory to Claude Code, Cursor, and any MCP-compatible AI client.",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "tangerine-mcp": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "tangerine",
    "team-memory",
    "claude",
    "cursor"
  ],
  "author": "Tangerine Intelligence",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Tangerine-Teams-Intelligence/tangerine-teams-app.git",
    "directory": "mcp-server"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "gray-matter": "^4.0.3",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.3.0",
    "vitest": "^1.6.0"
  }
}
